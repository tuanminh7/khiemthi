# Copy file nay thanh .env va thay gia tri cho phu hop.
SECRET_KEY=replace-with-a-random-secret
FLASK_DEBUG=0
APP_TITLE=Thu Vien Sach Noi AI
DATA_FILE=data/books.json
USERS_FILE=data/users.json
AUDIO_DIR=static/audio
AUDIO_PUBLIC_URL=/media/audio
COVER_UPLOAD_DIR=static/uploads/covers
AUTO_GENERATE_AUDIO_ON_ADD=0
RECOVER_AUDIO_JOBS_ON_STARTUP=0
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=Quan tri vien
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=300

